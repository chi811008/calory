{
  "name": "calory-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:init": "wrangler d1 execute calory-db --local --file=src/db/schema.sql",
    "db:init:remote": "wrangler d1 execute calory-db --remote --file=src/db/schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.5.4",
    "vitest": "^3.2.6",
    "wrangler": "^4.99.0"
  }
}
